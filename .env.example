# =============================================================================
# Mínimo para E2E (sandbox DIGID + Postgres local)
# Copia este archivo a .env y completa los valores. No subas .env al repo.
# =============================================================================

# En producción, no definas esto. En staging de prueba: JUXA_SHOW_TEST_CREDENTIALS=1 para mostrar
# usuario/contraseña de prueba en la pantalla de login (solo si aceptas el riesgo).
# JUXA_SHOW_TEST_CREDENTIALS=1

# -----------------------------------------------------------------------------
# Modo sin base de datos (desarrollo / demo local) — en implementación gradual
# -----------------------------------------------------------------------------
# JUXA_DATA_STORE=memory  →  usar almacén en memoria (no llamar prisma en runtime).
# Con memoria, `npm run db:seed` no toca Postgres (sale enseguida; la semilla es memory-store al arrancar el servidor).
# Mientras migres, deja comentado y usa Postgres como siempre.
# Con memoria: por defecto DIGID va en simulación (mock), salvo que fuerces API real con DIGID_MOCK=0.
# Con Postgres y sin DIGID_MOCK=1: se usa la API DIGID si las variables DIGID_* están completas.
# DIGID_MOCK=1 → siempre mock · DIGID_MOCK=0 → siempre API real (útil con sandbox).
# Semilla en memoria: org + ADMIN (JUXA_MEMORY_PANEL_EMAIL / JUXA_MEMORY_DEMO_PASSWORD) +
# OPERATOR (inicio tipo producto) + SANDBOX (checklist sandbox y avance MVP en inicio) +
# VIEWER (solo visualización). NextAuth; con DEMO_PASSWORD
# la cookie demo puede omitir DEMO_ORGANIZATION_ID (se usa getMemoryDefaultOrganizationId()).
# JUXA_DATA_STORE=memory
# Administrador del panel en memoria (ADMIN)
# JUXA_MEMORY_PANEL_EMAIL="admin@tu-empresa.local"
# JUXA_MEMORY_DEMO_PASSWORD="cambia-esto"
# Operador en memoria (OPERATOR: envíos, folios; inicio sin ayudas de sandbox)
# JUXA_MEMORY_OPERATOR_EMAIL="operador@tu-empresa.local"
# JUXA_MEMORY_OPERATOR_PASSWORD="cambia-esto"
# Pruebas en memoria (SANDBOX: permisos como operador + ayudas de sandbox en inicio)
# JUXA_MEMORY_SANDBOX_EMAIL="pruebas@tu-empresa.local"
# JUXA_MEMORY_SANDBOX_PASSWORD="cambia-esto"
# Solo visualización en memoria (VIEWER)
# JUXA_MEMORY_VIEWER_EMAIL="observador@tu-empresa.local"
# JUXA_MEMORY_VIEWER_PASSWORD="cambia-esto"
# DEMO_ORGANIZATION_ID=""
# DIGID_MOCK=1
# Para sandbox DIGID real con Postgres: comenta memoria, pon credenciales y:
# DIGID_MOCK=0

# PostgreSQL (Prisma)
# Con Docker: npm run db:docker  →  credenciales abajo
DATABASE_URL="postgresql://juxa:juxa@localhost:5432/juxa_sign?schema=public"

# DIGID — nunca commitear valores reales
DIGID_API_BASE="https://dev.digidmexico.com.mx/api/ws"
DIGID_LEGACY_BASE="https://dev.digidmexico.com.mx/wsdigid3/public/index.php"
DIGID_USUARIO=""
DIGID_CLAVE=""
DIGID_TOKEN=""
DIGID_MODO="T"

# URL pública de la app. En local debe coincidir con `npm run dev` (puerto fijo 3333 en package.json).
# Si cambias de puerto, actualiza esto y la vista Simple Browser del IDE (o abre la URL que imprime la terminal).
NEXT_PUBLIC_APP_URL="http://localhost:3333"

# Opcional: mismo host/puerto que `npm run dev` para enlaces de firma en correos cuando DIGID está en mock.
# Si no la defines, se usa NEXT_PUBLIC_APP_URL. Útil si el público quedó en :3000 pero corres en :3333.
# JUXA_LOCAL_SIGNING_BASE_URL="http://localhost:3333"

# En producción, habilita /superadmin/prueba-envio-firma (solo si lo necesitas; por defecto off).
# JUXA_SUPERADMIN_SIGNING_LAB=1

# =============================================================================
# Acceso al panel
# =============================================================================
# NextAuth (inicio de sesión con usuario en BD). Solo aplica si NO defines DEMO_PASSWORD.
# Genera secreto: openssl rand -base64 32
# AUTH_SECRET=""
# En local con NextAuth, si el login falla por host/callback, alinea con el puerto de dev:
# AUTH_URL="http://localhost:3333"
# En despliegue con dominio fijo (opcional): AUTH_URL="https://tu-dominio.com"
#
# Seed (npm run db:seed): bcrypt en BD
# ADMIN_EMAIL="admin@tu-dominio.com"
# ADMIN_PASSWORD="cambia-esto"
# Opcional: operador SaaS (misma org; envíos y consumo de folios; inicio sin ayudas de sandbox)
# OPERATOR_EMAIL="operador@tu-dominio.com"
# OPERATOR_PASSWORD="cambia-esto"
#
# Opcional: cuenta interna de pruebas (SANDBOX: mismo panel que operador + checklist sandbox y avance MVP en inicio)
# SANDBOX_EMAIL="pruebas@tu-dominio.com"
# SANDBOX_PASSWORD="cambia-esto"
#
# Opcional: operador plataforma /superadmin (misma org default por FK; no uses el mismo correo que ADMIN)
# SUPERADMIN_EMAIL="superadmin@tu-dominio.com"
# SUPERADMIN_PASSWORD="cambia-esto"
#
# Modo JUXA_DATA_STORE=memory: superadmin adicional opcional
# JUXA_MEMORY_SUPERADMIN_EMAIL="super@juxa.local"
# JUXA_MEMORY_SUPERADMIN_PASSWORD="cambia-esto"
#
# Opcional: rol USER (consumidor de folios; misma org; invitable desde Equipo)
# USER_EMAIL="folios@tu-dominio.com"
# USER_PASSWORD="cambia-esto"
#
# Opcional: rol VIEWER (solo visualización; misma org; invitable desde Equipo)
# VIEWER_EMAIL="observador@tu-dominio.com"
# VIEWER_PASSWORD="cambia-esto"
#
# Desactivar descuento de cartera al enviar (solo pruebas automatizadas / diagnóstico)
# JUXA_SKIP_FOLIO_DEBIT=1

# Protección rápida para demos: una contraseña compartida (cookie firmada). Si está definida,
# el middleware NO exige sesión NextAuth. Requiere también DEMO_AUTH_SECRET (p. ej. openssl rand -hex 32).
# Para que las server actions funcionen, indica el cuid de una Organization existente:
# DEMO_ORGANIZATION_ID=""
# DEMO_PASSWORD=""
# DEMO_AUTH_SECRET=""
#
# Con DEMO_PASSWORD no hay sesión NextAuth con rol: /superadmin queda bloqueado (solo credenciales + SUPERADMIN).

# =============================================================================
# Opcional — webhook
# =============================================================================
# Secreto en query (?secret=) para validar llamadas entrantes a /api/webhooks/digid
DIGID_WEBHOOK_SECRET=""

# Proxy PDF (/api/proxy-pdf): en npm run dev se permite obtener PDFs desde localhost/127.0.0.1.
# En build de producción, localhost queda bloqueado salvo JUXA_PROXY_PDF_ALLOW_LOCALHOST=1
# (solo en entornos controlados; reduce riesgo de abuso tipo SSRF hacia servicios internos).
# JUXA_PROXY_PDF_ALLOW_LOCALHOST=1

# =============================================================================
# Antes de producción
# =============================================================================
# Con dominio ya definido: NEXT_PUBLIC_APP_URL=https://tu-dominio.com y DIGID_WEBHOOK_SECRET.
# Sin URL aún: deja localhost o vacío y usa  npm run check:env:production:pending-url
# Cierre final: npm run check:env:production  (ver docs/despliegue.md)

# =============================================================================
# Opcional — seed y depuración webhook en producción
# =============================================================================
# Seed (prisma db seed): por defecto solo si DATABASE_URL parece local (localhost,
# host db en compose, o usuario juxa:juxa). Para forzar en otra URL: JUXA_ALLOW_SEED=1
# JUXA_ALLOW_SEED=1
#
# Tabla "Últimos webhooks" en /configuracion: en producción oculta salvo:
# JUXA_WEBHOOK_DEBUG_UI=1

# =============================================================================
# Opcional — correo transaccional (servidor; nunca expongas API keys al cliente)
# =============================================================================
# Usos hoy: correo a firmantes al enviar (JUXA_NOTIFY_SIGNERS o MAIL_PROVIDER resend/smtp), copia al observador (si indicó email), webhook (JUXA_WEBHOOK_NOTIFY=1).
#
# MAIL_PROVIDER=none | resend | smtp
# none: en desarrollo se registra [mail:skip] en consola del servidor; en producción no envía (salvo JUXA_MAIL_REQUIRED=1).
# MAIL_PROVIDER=none
#
# Remitente (Resend y SMTP). Debe ser un remitente válido para tu proveedor.
# MAIL_FROM="Juxa Sign <notificaciones@tu-dominio.com>"
#
# --- Prueba rápida: Resend (https://resend.com) — API key, dominio o onboarding@resend.dev ---
# MAIL_PROVIDER=resend
# RESEND_API_KEY="re_..."
# MAIL_FROM="Juxa Sign <onboarding@resend.dev>"
#
# --- Prueba local: Mailpit (https://github.com/axllent/mailpit) captura SMTP sin enviar a internet ---
# docker run -d --name mailpit -p 8025:8025 -p 1025:1025 axllent/mailpit
# MAIL_PROVIDER=smtp
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025
# SMTP_SKIP_AUTH=1
# MAIL_FROM="Juxa Sign <prueba@localhost>"
#
# --- SMTP con autenticación (Mailtrap, SendGrid SMTP, tu servidor, etc.) ---
# MAIL_PROVIDER=smtp
# SMTP_HOST="smtp.mailtrap.io"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_SECURE=1   # opcional; TLS implícito en puerto 465
#
# Si JUXA_MAIL_REQUIRED=1 y no hay proveedor configurado, las acciones que envían correo fallan.
# JUXA_MAIL_REQUIRED=1
#
# Invitación en Configuración → Equipo: con MAIL_PROVIDER=resend|smtp se envía el enlace /invitacion/… al correo del invitado.
#
# Tras enviar a firmar: a cada firmante con email se envía enlace personal de firma (si MAIL_PROVIDER=resend|smtp), salvo JUXA_NOTIFY_SIGNERS=0.
# JUXA_NOTIFY_SIGNERS=0
#
# Tras enviar a firmar: copia informativa al email del observador (si lo rellenó), con el mismo MAIL_PROVIDER que firmantes.
# Para no enviar esa copia (DIGID sigue recibiendo datos del observador): JUXA_NOTIFY_OBSERVER=0
# JUXA_NOTIFY_OBSERVER=0
#
# Legado: si aún usas JUXA_NOTIFY_SIGNING=1 no hace falta para la copia al observador (ahora se intenta por defecto).
#
# Webhook DIGID: notificar a admins de la organización del documento cuando cambia el estado.
# JUXA_WEBHOOK_NOTIFY=1
# Correos extra (coma), además de ADMIN de la org: JUXA_WEBHOOK_NOTIFY_EMAILS="a@x.com,b@y.com"

# =============================================================================
# Opcional — compatibilidad API
# =============================================================================
# Serialización de FolioPremium (send_doc) y kyc por firmante (add_assigned_doc).
# Por defecto: 0/1. Si el sandbox exige boolean JSON:
# DIGID_FLAG_SERIALIZATION=boolean
