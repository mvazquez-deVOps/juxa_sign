{
  "name": "juxa-sign",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev -p 3333",
    "dev:free": "node scripts/dev-free-port.mjs",
    "dev:3000": "next dev --turbopack -p 3000",
    "dev:3008": "next dev --turbopack -p 3008",
    "dev:3010": "next dev --turbopack -p 3010",
    "build": "prisma generate && next build",
    "vercel-build": "prisma migrate deploy && npm run build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "check:env": "node scripts/check-env.mjs",
    "check:env:production": "node scripts/check-env.mjs --production",
    "check:env:production:pending-url": "node scripts/check-env.mjs --production --pending-url",
    "predeploy": "npm run lint && npm run build",
    "test:e2e": "playwright install chromium && playwright test",
    "test:e2e:ui": "playwright install chromium && playwright test --ui",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:docker": "docker compose up -d",
    "db:docker:down": "docker compose down"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^6.3.1",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.468.0",
    "next": "15.1.3",
    "next-auth": "5.0.0-beta.25",
    "next-themes": "^0.4.4",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^6.10.1",
    "pdfjs-dist": "3.11.174",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.4.7",
    "eslint": "^9",
    "eslint-config-next": "15.1.3",
    "postcss": "^8",
    "prisma": "^6.3.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
